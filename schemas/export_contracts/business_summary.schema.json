{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "export_contracts/business_summary.schema.json",
  "title": "Business Summary Export",
  "type": "object",
  "required": [
    "contract_name",
    "contract_version",
    "source",
    "generated_at_utc",
    "classification",
    "seed",
    "inputs",
    "key_metrics",
    "trace",
    "risk_flags",
    "claim_boundaries",
    "non_claims",
    "network_calls_made"
  ],
  "properties": {
    "contract_name": { "type": "string", "const": "business_summary" },
    "contract_version": { "type": "string" },
    "source": { "type": "object" },
    "generated_at_utc": { "type": "string" },
    "classification": { "type": "string", "const": "portfolio_demo" },
    "seed": { "type": "integer" },
    "preset": { "type": "string" },
    "inputs": { "type": "object" },
    "key_metrics": {
      "type": "object",
      "required": ["irr", "npv", "coc", "equity_multiple", "risk"],
      "properties": {
        "irr": { "type": "object" },
        "npv": { "type": "object" },
        "coc": { "type": "object" },
        "equity_multiple": { "type": "object" },
        "risk": { "type": "object" }
      }
    },
    "trace": { "type": "object" },
    "risk_flags": { "type": "array" },
    "safe_claims": { "type": "array", "minItems": 1 },
    "claim_boundaries": { "type": "array", "minItems": 1 },
    "non_claims": { "type": "array", "minItems": 1 },
    "network_calls_made": { "type": "boolean", "const": false }
  }
}
